---
import { useTranslations } from "../i18n/utils";
import Disclaimer from "./Disclaimer.astro";
import PrivacyPromise from "./PrivacyPromise.astro";
const t = useTranslations();

// External destination — the site has no backend, so error reports go to the
// public issue tracker. Not user-facing prose, so it lives here, not in ui.ts.
const reportUrl = "https://github.com/PinePeakDigital/opennok/issues/new";
---

<footer class="site-footer">
	<div class="container">
		<Disclaimer />
		<PrivacyPromise />
		<nav class="footer-links" aria-label={t("footer.nav")}>
			<a href={reportUrl}>{t("footer.reportError")}</a>
		</nav>
		<p class="license">{t("footer.license")}</p>
	</div>
</footer>

<style>
	.site-footer {
		border-top: var(--border-width) solid var(--border);
		background: var(--surface);
		padding-block: var(--space-8);
		font-size: var(--text-sm);
	}
	.footer-links {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-6);
		font-family: var(--font-sans);
		margin-top: var(--space-6);
	}
	.license {
		color: var(--text-muted);
		margin-top: var(--space-4);
		margin-bottom: 0;
	}
</style>

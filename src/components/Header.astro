---
import { useTranslations } from "../i18n/utils";
const t = useTranslations();

// Mark the current section for screen readers. A section link is "current" on
// its own index and on any page nested beneath it (e.g. /guide/getting-started).
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isCurrent = (href: string) => path === href || path.startsWith(href + "/");
---

<header class="site-header">
	<div class="container header-inner">
		<a href="/" class="brand">{t("site.title")}</a>
		<nav aria-label={t("nav.main")}>
			<a href="/guide" aria-current={isCurrent("/guide") ? "page" : undefined}>
				{t("nav.guide")}
			</a>
			<a
				href="/glossary"
				aria-current={isCurrent("/glossary") ? "page" : undefined}
			>
				{t("nav.glossary")}
			</a>
			<a href="/guide/getting-started" class="cta">{t("nav.quickStart")}</a>
		</nav>
	</div>
</header>

<style>
	.site-header {
		border-bottom: var(--border-width) solid var(--border);
		background: var(--surface);
	}
	.header-inner {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		justify-content: space-between;
		gap: var(--space-4);
		padding-block: var(--space-4);
	}
	.brand {
		font-family: var(--font-sans);
		font-weight: 700;
		font-size: var(--text-xl);
		color: var(--text);
		text-decoration: none;
	}
	nav {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: var(--space-6);
		font-family: var(--font-sans);
	}
	nav a[aria-current="page"] {
		text-decoration-thickness: 2px;
		text-underline-offset: 0.2em;
		font-weight: 600;
	}
	.cta {
		text-decoration: none;
		font-weight: 600;
		padding: var(--space-1) var(--space-3);
		border: var(--border-width) solid var(--link);
		border-radius: var(--radius);
	}
	.cta:hover {
		border-color: var(--link-hover);
	}
</style>
